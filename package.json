{
  "name": "workout",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "dev": "node scripts/start-expo-lan.js",
    "dev:go": "node scripts/start-expo-lan.js --go",
    "dev:tunnel": "expo start --tunnel --clear --dev-client",
    "dev:tunnel:go": "expo start --tunnel --clear --go",
    "dev:localhost": "expo start --localhost",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "ios:dev": "expo run:ios",
    "ios:prebuild": "expo prebuild --platform ios --clean",
    "build:ios:dev": "eas build --profile development --platform ios",
    "build:ios:sim": "eas build --profile development-simulator --platform ios",
    "web": "expo start --web",
    "test": "jest",
    "firebase:deploy": "firebase deploy --only firestore,auth"
  },
  "dependencies": {
    "@expo/ngrok": "^4.1.3",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "date-fns": "^4.2.1",
    "expo": "~54.0.33",
    "expo-auth-session": "~7.0.11",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-dev-client": "~6.0.20",
    "expo-font": "~14.0.12",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-keep-awake": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-router": "~6.0.23",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.11",
    "firebase": "^12.13.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "~19.1.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.10",
    "typescript": "~5.9.2"
  },
  "private": true
}
