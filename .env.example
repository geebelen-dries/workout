EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
# Google Calendar — see docs/GOOGLE_CALENDAR.md
# Web client: add redirect URI from Week tab → Connect calendar alert
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# iOS client: Expo Go → bundle host.exp.Exponent | dev build → com.workout.app
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
# Optional: force OAuth redirect (must match Web client authorized URI)
# EXPO_PUBLIC_GOOGLE_REDIRECT_URI=exp://192.168.0.206:8081/--/oauthredirect
# Calendar to show on Week tab (omit = account primary calendar)
# EXPO_PUBLIC_GOOGLE_CALENDAR_ID=your-id@group.calendar.google.com
EXPO_PUBLIC_STRAVA_CLIENT_ID=
EXPO_PUBLIC_STRAVA_CLIENT_SECRET=
# Expo Go on iPhone only — must match Strava callback domain (your Mac LAN IP).
# Omit for dev build (npx expo run:ios) — uses stable workout://workout.app/strava-auth
# EXPO_PUBLIC_STRAVA_REDIRECT_URI=http://10.1.81.101
